{
  "name": "prova-pdf",
  "version": "0.1.0",
  "type": "module",
  "description": "Purpose-built exam PDF generator compiled to WebAssembly",
  "main": "prova_pdf.js",
  "module": "prova_pdf.js",
  "types": "prova_pdf.d.ts",
  "files": [
    "prova_pdf.js",
    "prova_pdf_bg.wasm",
    "prova_pdf_bg.wasm.d.ts",
    "prova_pdf.d.ts",
    "prova-pdf.d.ts",
    "index.js"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./prova_pdf.d.ts",
      "import": "./prova_pdf.js",
      "default": "./prova_pdf.js"
    },
    "./index": {
      "types": "./prova-pdf.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "keywords": ["pdf", "wasm", "exam", "prova"],
  "license": "MIT",
  "author": "Dickson Pinheiro",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dickson-Pinheiro/prova-pdf"
  },
  "homepage": "https://github.com/Dickson-Pinheiro/prova-pdf"
}
